# MFDS API keys — two separate systems

# 1. 공공데이터포털 식약처 API (의약품 마스터, DUR, e약은요)
#    Get key at https://www.data.go.kr  (search "식품의약품안전처")
MFDS_API_KEY=your_mfds_api_key_here

# 2. 식품안전나라 OpenAPI (건강기능식품)
#    Get key at https://www.foodsafetykorea.go.kr
#    (공유서비스 → OpenAPI → 회원가입 + 키 발급)
FOODSAFETYKOREA_API_KEY=your_foodsafetykorea_api_key_here
